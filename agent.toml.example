[model]
name = "claude-sonnet-4-6"
# provider = "vertex-ai"    # vertex-ai, anthropic, google-genai (auto-detected if omitted)

# [thinking]
# level = "medium"          # minimal, low, medium, high (Gemini 3+ models)
# budget = 1024             # token budget (Gemini 2.5 models, -1 for dynamic)

# [providers.vertex-ai]
# json = "~/keys/vertex.json"
# project = "my-project"
# region = "us-east5"

# [providers.anthropic]
# uses ANTHROPIC_API_KEY env var

# [providers.google-genai]
# uses GOOGLE_API_KEY env var

# [agent]
# Selects which agent backend the simple loop drives. The default is
# "deepagents", which uses langchain + deepagents and supports Docker
# sandboxing. Setting backend = "cli" instead drives an external coding-agent
# CLI (Claude Code, Gemini, Codex, or Opencode) via vibe_serve/_agent_cli.
#
# CLI flags --agent-backend / --cli-provider on `vibeserve-loop` override
# these values.
# backend = "deepagents"      # or "cli"
# cli_provider = "claude"     # required when backend = "cli";
                              # one of: claude, gemini, codex, opencode
# cli_timeout = 1800          # per-iteration timeout in seconds (default: no timeout)

# [feature_flags]
# VibeServe feature flags are declared in src/vibe_serve/features.py.

# [backend]
# Hardware/runtime backend the serving stack targets. Supported values:
#   "cuda"  — NVIDIA container, nvidia-smi GPU selection, nsys profiler,
#             FlashInfer-style optimizations. Fully wired into the
#             curriculum.
#   "metal" — Apple Silicon via MPS / MLX (local execution only;
#             --docker and --modal are unavailable). The curriculum
#             templates are still CUDA-flavoured, so use this with
#             `vibeserve-loop` / ad-hoc workflows rather than
#             `vibeserve-curriculum`.
#
# CLI flag --backend on `vibeserve-loop` / `vibeserve-curriculum` overrides
# this value.
# name = "cuda"
