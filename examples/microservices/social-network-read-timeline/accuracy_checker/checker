#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

jobs="${CMAKE_BUILD_PARALLEL_LEVEL:-}"
if [[ -z "$jobs" ]]; then
  jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 4)"
fi

cmake -S . -B build -DCMAKE_BUILD_TYPE=Release >/dev/null
cmake --build build --parallel "$jobs" >/dev/null
exec ./build/checker "$@"
