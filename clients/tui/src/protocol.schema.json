{
  "$defs": {
    "ChatData": {
      "properties": {
        "kind": {
          "const": "chat",
          "default": "chat",
          "title": "Kind",
          "type": "string"
        },
        "answer": {
          "title": "Answer",
          "type": "string"
        }
      },
      "required": [
        "answer"
      ],
      "title": "ChatData",
      "type": "object"
    },
    "ChatQuery": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "query.chat",
          "default": "query.chat",
          "title": "Type",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ChatQuery",
      "type": "object"
    },
    "ChatResult": {
      "additionalProperties": false,
      "properties": {
        "question": {
          "title": "Question",
          "type": "string"
        },
        "answer": {
          "title": "Answer",
          "type": "string"
        },
        "effect": {
          "const": "none",
          "default": "none",
          "title": "Effect",
          "type": "string"
        }
      },
      "required": [
        "question",
        "answer"
      ],
      "title": "ChatResult",
      "type": "object"
    },
    "CommandAck": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "pause",
            "resume"
          ],
          "title": "Action",
          "type": "string"
        },
        "status": {
          "enum": [
            "pending",
            "consumed"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "action",
        "status"
      ],
      "title": "CommandAck",
      "type": "object"
    },
    "EventStatus": {
      "enum": [
        "active",
        "answered",
        "pending",
        "consumed",
        "completed",
        "failed"
      ],
      "title": "EventStatus",
      "type": "string"
    },
    "EventType": {
      "enum": [
        "server_started",
        "chat",
        "status_query",
        "control",
        "invocation_started",
        "invocation_finished",
        "run_finished",
        "run_failed",
        "output"
      ],
      "title": "EventType",
      "type": "string"
    },
    "EventsQuery": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "query.events",
          "default": "query.events",
          "title": "Type",
          "type": "string"
        },
        "after_sequence": {
          "default": 0,
          "minimum": 0,
          "title": "After Sequence",
          "type": "integer"
        },
        "timeout_ms": {
          "default": 0,
          "maximum": 30000,
          "minimum": 0,
          "title": "Timeout Ms",
          "type": "integer"
        }
      },
      "title": "EventsQuery",
      "type": "object"
    },
    "HistoryQuery": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "query.history",
          "default": "query.history",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "HistoryQuery",
      "type": "object"
    },
    "InvocationFinishedData": {
      "properties": {
        "kind": {
          "const": "invocation_finished",
          "default": "invocation_finished",
          "title": "Kind",
          "type": "string"
        },
        "result": {
          "default": null,
          "title": "Result"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "title": "InvocationFinishedData",
      "type": "object"
    },
    "InvocationStartedData": {
      "properties": {
        "kind": {
          "const": "invocation_started",
          "default": "invocation_started",
          "title": "Kind",
          "type": "string"
        },
        "system_prompt": {
          "title": "System Prompt",
          "type": "string"
        },
        "user_prompt": {
          "title": "User Prompt",
          "type": "string"
        }
      },
      "required": [
        "system_prompt",
        "user_prompt"
      ],
      "title": "InvocationStartedData",
      "type": "object"
    },
    "OutputData": {
      "properties": {
        "kind": {
          "const": "output",
          "default": "output",
          "title": "Kind",
          "type": "string"
        },
        "stream": {
          "enum": [
            "stdout",
            "stderr"
          ],
          "title": "Stream",
          "type": "string"
        },
        "source": {
          "default": "backend",
          "title": "Source",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "stream",
        "content"
      ],
      "title": "OutputData",
      "type": "object"
    },
    "PauseCommand": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "command.pause",
          "default": "command.pause",
          "title": "Type",
          "type": "string"
        },
        "mode": {
          "const": "after_current_agent_call",
          "default": "after_current_agent_call",
          "title": "Mode",
          "type": "string"
        }
      },
      "title": "PauseCommand",
      "type": "object"
    },
    "Response": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "ok": {
          "default": true,
          "title": "Ok",
          "type": "boolean"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "ack": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommandAck"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "chat": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChatResult"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "snapshot": {
          "anyOf": [
            {
              "$ref": "#/$defs/RunSnapshot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "events": {
          "items": {
            "$ref": "#/$defs/RunEvent"
          },
          "title": "Events",
          "type": "array"
        }
      },
      "required": [
        "request_id"
      ],
      "title": "Response",
      "type": "object"
    },
    "ResumeCommand": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "command.resume",
          "default": "command.resume",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "ResumeCommand",
      "type": "object"
    },
    "RunEvent": {
      "additionalProperties": false,
      "description": "One reproducible human, control, or invocation event.",
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "sequence": {
          "default": 0,
          "minimum": 0,
          "title": "Sequence",
          "type": "integer"
        },
        "run_id": {
          "default": "",
          "title": "Run Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/EventType"
        },
        "text": {
          "default": "",
          "title": "Text",
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "round_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Round Label"
        },
        "agent_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Kind"
        },
        "invocation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invocation Id"
        },
        "data": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "chat": "#/$defs/ChatData",
                  "invocation_finished": "#/$defs/InvocationFinishedData",
                  "invocation_started": "#/$defs/InvocationStartedData",
                  "output": "#/$defs/OutputData"
                },
                "propertyName": "kind"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/ChatData"
                },
                {
                  "$ref": "#/$defs/InvocationStartedData"
                },
                {
                  "$ref": "#/$defs/InvocationFinishedData"
                },
                {
                  "$ref": "#/$defs/OutputData"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        }
      },
      "required": [
        "timestamp",
        "type"
      ],
      "title": "RunEvent",
      "type": "object"
    },
    "RunSnapshot": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "sequence": {
          "title": "Sequence",
          "type": "integer"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "agent_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Kind"
        },
        "round_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Round Label"
        }
      },
      "required": [
        "run_id",
        "sequence",
        "status"
      ],
      "title": "RunSnapshot",
      "type": "object"
    },
    "SnapshotQuery": {
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1,
          "default": 1,
          "title": "Protocol Version",
          "type": "integer"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "const": "query.snapshot",
          "default": "query.snapshot",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "SnapshotQuery",
      "type": "object"
    }
  },
  "properties": {
    "request": {
      "discriminator": {
        "mapping": {
          "command.pause": "#/$defs/PauseCommand",
          "command.resume": "#/$defs/ResumeCommand",
          "query.chat": "#/$defs/ChatQuery",
          "query.events": "#/$defs/EventsQuery",
          "query.history": "#/$defs/HistoryQuery",
          "query.snapshot": "#/$defs/SnapshotQuery"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/PauseCommand"
        },
        {
          "$ref": "#/$defs/ResumeCommand"
        },
        {
          "$ref": "#/$defs/SnapshotQuery"
        },
        {
          "$ref": "#/$defs/ChatQuery"
        },
        {
          "$ref": "#/$defs/HistoryQuery"
        },
        {
          "$ref": "#/$defs/EventsQuery"
        }
      ],
      "title": "Request"
    },
    "response": {
      "$ref": "#/$defs/Response"
    },
    "event": {
      "$ref": "#/$defs/RunEvent"
    },
    "snapshot": {
      "$ref": "#/$defs/RunSnapshot"
    }
  },
  "required": [
    "request",
    "response",
    "event",
    "snapshot"
  ],
  "title": "ProtocolDocument",
  "type": "object"
}
