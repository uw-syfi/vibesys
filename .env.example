# Copy to .env and fill these in before running vibesys-agent.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional — only needed for gated HuggingFace models (auto-uploaded to a
# Modal Volume on first --modal run).
HF_TOKEN=

# For Vertex AI authentication
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_PROJECT=
VERTEX_REGION=us-east5

# Provider-specific settings (for agent_system orchestrator)
OPENAI_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

VLLM_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1

ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/v1
ZAI_MODEL=glm-4-flash
